# ─────────────────────────────────────────────────────────────────────────────
# Minutely — environment variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── AI provider ──────────────────────────────────────────────────────────────
# Primary model used by all 6 agents in the orchestrator.
# Currently configured for OpenAI-compatible endpoints (OpenRouter, Together, etc.)

AI_API_KEY=                          # your provider API key
AI_BASE_URL=https://openrouter.ai/api/v1/chat/completions
AI_PRIMARY_MODEL=qwen/qwen3-235b-a22b

# Set to "true" on Tuesdays to activate the Qwen coupon pricing path
QWEN_COUPON_ACTIVE=false


# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=            # https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=       # public anon key (safe to expose)
SUPABASE_SERVICE_ROLE_KEY=           # service role key (server-only — never expose client-side)


# ── Clerk auth ───────────────────────────────────────────────────────────────
# Get these from clerk.com → your app → API Keys

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=   # pk_...
CLERK_SECRET_KEY=                    # sk_...

# Redirect paths after sign-in / sign-up (optional — defaults shown)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/upload
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/upload


# ── Slack integration (optional) ─────────────────────────────────────────────
# If not set, /api/send-followup will dry-run (logs but does not post).
# Create an Incoming Webhook at api.slack.com/apps

SLACK_WEBHOOK_URL=                   # https://hooks.slack.com/services/xxx/yyy/zzz


# ── Google OAuth / Calendar (optional) ───────────────────────────────────────
# Required for "Schedule in Google Calendar" in the follow-up modal.
# Set up at console.cloud.google.com → APIs & Services → Credentials

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/integrations/callback


# ── Notion integration (optional) ────────────────────────────────────────────
# Per-user tokens are stored in user_integrations (set via /integrations page).
# No server-level Notion key needed — OAuth tokens are fetched from DB per request.
# If you want a fallback workspace token for testing:
NOTION_TEST_TOKEN=                   # secret_...


# ── Resend / email (optional) ────────────────────────────────────────────────
# Email sending has been removed from the active follow-up flow.
# This key is kept here in case it is re-enabled.
RESEND_API_KEY=                      # re_...


# ── App config ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
